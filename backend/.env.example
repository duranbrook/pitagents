# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/autoshop

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Deepgram
DEEPGRAM_API_KEY=...

# AWS S3 / R2
S3_BUCKET=autoshop-media
S3_ENDPOINT_URL=https://...r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...

# Twilio
TWILIO_ACCOUNT_SID=...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_PHONE=+1...

# SendGrid
SENDGRID_API_KEY=SG....

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Pricing flag (per-shop override, but set default here)
DEFAULT_PRICING_SOURCE=shop

# ALLDATA (optional)
ALLDATA_API_KEY=
ALLDATA_API_URL=https://api.alldata.com/v1

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Gemini (embeddings via text-embedding-004)
GEMINI_API_KEY=AIza...
